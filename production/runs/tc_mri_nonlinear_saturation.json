    "source": "local WKB MRI, taylor_couette_mhd_conducting_v1, taylor_couette_mhd_dns_v1, then GPU-generated saturated DNS golden",
    "fallback_rungs": [1, 2, 3],
    "saturation_check": "E_mag[-1] > 2*E_mag[0] and monotone-then-plateau; do not apply fixed linear growth factor at saturation"
