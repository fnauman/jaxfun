    "y": "azimuthal direction",
    "z": "axial direction"
  },
  "native_axes": {
    "axis_0": "r radial",
    "axis_1": "theta azimuthal",
    "axis_2": "z axial"
  },
  "nondimensional_groups": {
    "Re": 1000.0,
    "Rm": 1000.0,
    "Pm": 1.0,
    "R1": 1.0,
    "R2": 2.0,
    "radius_ratio": 0.5,
    "Omega1": 1.0,
    "Omega2": 0.3535533905932738,
    "B0": 0.1,
    "nu": 0.001,
    "eta_mag": 0.001
  },
  "boundary_conditions": {
    "velocity": {"type": "no_slip_rotating_cylinders"},
    "magnetic": {
      "type": "conducting",
      "details": "b_r=0, d(r b_theta)/dr=0, d b_z/dr=0"
    }
  },
  "domain": {
    "r": [1.0, 2.0],
    "theta_period": 6.283185307179586,
    "z_period": 1.0471975511965976
  },
  "resolution": {
    "start": {"Nr": 40, "Nz": 24},
    "production": {"Nr": 64, "Nz": 48},
    "dealias": 1.5,
    "family": "C"
  },
  "time": {
    "integrator": "CNAB2",
    "dt": 0.002,
    "final_time": 32.0
  },
  "mode": {
    "azimuthal_wavenumber": 0,
    "axial_wavenumber": 6.0
  },
  "initial_condition": {
    "type": "linear_eigenmode",
    "amplitude": 0.0001,
    "seeded_kz_mode": 1
  },
  "forcing": {
    "type": "rotating_cylinders_imposed_axial_field",
    "B0": 0.1
  },
  "diagnostics": [
    "magnetic_energy",
    "growth_rate",
    "maxwell_stress_xy",
    "divergence_b_l2",
    "kinetic_energy"
