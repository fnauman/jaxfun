{
  "family": "shenfun",
  "problem_id": "exp_pcf_mri_vector_potential",
  "geometry": "pcf",
  "physics": "mri",
  "support_state": "experimental",
  "numerics_contract_version": 2,
  "precision": "float64",
  "representation": "vector_potential",
  "formulation": {
    "internal": "curl/vector-potential PCF MRI/shearbox DNS: B = B0 + curl A with A evolved (solenoidal by construction)",
    "pressure": "KMM velocity-vorticity flow block; no magnetic pressure variable"
  },
  "evolved_variables": ["u_x", "u_y", "u_z", "A_x", "A_y", "A_z"],
  "diagnostic_variables": ["kinetic_energy", "magnetic_energy", "maxwell_stress_xy", "reynolds_stress", "alpha_Sh", "mean_bx", "mean_by", "mean_bz"],
  "canonical_axes": {
    "x": "wall-normal/shear-gradient direction",
    "y": "streamwise direction",
    "z": "spanwise/vertical-field direction"
  },
  "native_axes": {
    "axis_0": "x wall-normal (Chebyshev/Legendre)",
    "axis_1": "y streamwise (Fourier)",
    "axis_2": "z spanwise/vertical (Fourier)"
  },
  "nondimensional_groups": {
    "Re": 1000.0,
    "Rm": 1000.0,
    "Pm": 1.0,
    "Omega": 0.6666666666666666,
    "S": 1.0,
    "q_shear": 1.5,
    "B0": 0.025,
    "nu": 0.001,
    "eta_mag": 0.001
  },
  "boundary_conditions": {
    "velocity": {"type": "no_slip_shearbox_walls"},
    "magnetic": {
      "type": "conducting",
      "details": "A-formulation conducting walls; b = curl A is solenoidal to roundoff"
    }
  },
  "domain": {
    "x": [-1.0, 1.0],
    "y_period": 4.0,
    "z_period": 1.0
  },
  "resolution": {
    "smoke": {"Nx": 9, "Ny": 8, "Nz": 8, "dealias": 1.0},
    "start": {"Nx": 17, "Ny": 16, "Nz": 16},
    "production": {"Nx": 33, "Ny": 32, "Nz": 32},
    "dealias": {"x": 1.0, "y": 1.5, "z": 1.5},
    "family": "C"
  },
  "time": {
    "integrator": "IMEXRK222",
    "dt": 0.005,
    "final_time": 60.0
  },
  "initial_condition": {
    "type": "shearpy_channel_modes",
    "velocity_amplitude": 0.05,
    "magnetic_amplitude": 0.001
  },
  "forcing": {
    "type": "rotation_shear_imposed_vertical_field",
    "B0": 0.025,
    "by": 0.0,
    "bz": 0.025
  },
  "diagnostics": [
