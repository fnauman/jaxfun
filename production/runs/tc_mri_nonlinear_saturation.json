{
  "family": "shenfun",
  "problem_id": "tc_mri_nonlinear_saturation",
  "geometry": "taylor_couette",
  "physics": "mhd",
  "support_state": "experimental",
  "formulation": {
    "internal": "axisymmetric primitive resistive-MHD Taylor-Couette CNAB2 DNS with imposed axial field",
    "pressure": "total pressure Pi = p + B0 b_z"
  },
  "evolved_variables": ["u_r", "u_theta", "u_z", "Pi", "b_r", "b_theta", "b_z"],
