  "golden": {
    "artifact_id": "tc_mri_nonlinear_saturation",
    "regeneration_command": ".venv/bin/python production/run_problem.py --config production/runs/tc_mri_nonlinear_saturation.json --out runs/tc_mri_nonlinear_saturation/<timestamp> --device auto --write-golden"
