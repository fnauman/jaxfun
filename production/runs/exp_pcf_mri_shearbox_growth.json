{
  "family": "shenfun",
  "problem_id": "exp_pcf_mri_shearbox_growth",
  "geometry": "pcf",
  "physics": "mri",
  "support_state": "experimental",
  "formulation": {
    "internal": "primitive-b PCF MRI/shearbox DNS with direct magnetic-field evolution",
    "pressure": "primitive velocity pressure with direct magnetic components"
  },
  "evolved_variables": ["u_x", "u_y", "u_z", "p", "b_x", "b_y", "b_z"],
  "diagnostic_variables": ["kinetic_energy", "magnetic_energy", "maxwell_stress_xy", "reynolds_stress", "transport_alpha"],
  "canonical_axes": {
    "x": "wall-normal/shear-gradient direction",
    "y": "streamwise direction",
    "z": "spanwise/vertical-field direction"
  },
  "native_axes": {
    "axis_0": "x wall-normal",
    "axis_1": "y streamwise",
    "axis_2": "z spanwise"
  },
  "nondimensional_groups": {
    "Re": 1000.0,
    "Rm": 1000.0,
    "Pm": 1.0,
    "Omega": 0.6666666666666666,
    "S": 1.0,
    "q_shear": 1.5,
    "B0": 0.025,
    "nu": 0.001,
    "eta_mag": 0.001
  },
  "boundary_conditions": {
    "velocity": {"type": "no_slip_shearbox_walls"},
    "magnetic": {
      "type": "conducting",
      "details": "b_x=0, d_x b_y=d_x b_z=0"
    }
  },
  "domain": {
    "x": [-1.0, 1.0],
    "y_period": 4.0,
    "z_period": 1.0
  },
  "resolution": {
    "smoke": {"Nx": 8, "Ny": 4, "Nz": 8, "dealias": [1.0, 1.0, 1.0]},
    "start": {"Nx": 16, "Ny": 32, "Nz": 16},
    "production": {"Nx": 32, "Ny": 32, "Nz": 32},
    "dealias": [1.0, 1.5, 1.5],
    "family": "L"
  },
  "time": {
    "integrator": "IMEXRK222",
    "dt": 0.005,
    "final_time": 60.0
  },
  "initial_condition": {
    "type": "mri_eigenmode_packet",
    "amplitude": 0.001,
    "seeded_modes": {"ky": 0, "kz": [1, 2, 3]}
  },
  "forcing": {
    "type": "rotation_shear_imposed_vertical_field",
    "B0": 0.025,
    "by": 0.0,
    "bz": 0.025
  },
  "diagnostics": [
    "magnetic_energy",
    "growth_rate",
    "maxwell_stress_xy",
    "reynolds_stress",
    "transport_alpha",
    "divergence_b_l2",
    "butterfly_by_mean"
  ],
  "expected_oracle": {
    "type": "mri_saturation_ladder",
    "source": "local ideal MRI optimum, pcf_mri_shearbox_v1, pcf_mri_primitive_dns_v1, then GPU-generated saturated DNS golden",
    "plan_inventory_id": "exp_PCF_MRI_shearbox_growth",
    "fallback_rungs": [1, 2, 3],
    "linear_window_check": "growth over t in [1,3]; saturation uses E_mag[-1] > 2*E_mag[0] and monotone-then-plateau"
  },
  "tolerance_model": {
    "kind": "dns-production",
    "scalars": {
      "divergence_b_l2": 1e-10,
      "growth_rate": 0.002,
      "magnetic_energy": 0.000001,
      "maxwell_stress_xy": 0.000001
    }
  },
  "golden": {
    "artifact_id": "exp_pcf_mri_shearbox_growth",
    "regeneration_command": ".venv/bin/python production/run_problem.py --config production/runs/exp_pcf_mri_shearbox_growth.json --out runs/exp_pcf_mri_shearbox_growth/<timestamp> --device auto --write-golden"
  },
  "unsupported_subcases": []
}
