{
  "family": "shenfun",
  "problem_id": "exp_pcf_mri_pseudo_vacuum",
  "geometry": "pcf",
  "physics": "mri",
  "support_state": "experimental",
  "numerics_contract_version": 2,
  "representation": "primitive",
  "formulation": {
    "internal": "primitive-b PCF MRI/shearbox DNS with pseudo-vacuum magnetic walls (FJ-09 second BC)",
    "pressure": "primitive velocity pressure with direct magnetic components"
  },
  "evolved_variables": ["u_x", "u_y", "u_z", "p", "b_x", "b_y", "b_z"],
  "diagnostic_variables": ["kinetic_energy", "magnetic_energy", "maxwell_stress_xy", "reynolds_stress", "transport_alpha"],
  "canonical_axes": {
    "x": "wall-normal/shear-gradient direction",
    "y": "streamwise direction",
    "z": "spanwise/vertical-field direction"
  },
  "native_axes": {
    "axis_0": "y streamwise (Fourier)",
    "axis_1": "z spanwise/vertical (Fourier)",
    "axis_2": "x wall-normal (Chebyshev)"
  },
  "nondimensional_groups": {
    "Re": 1000.0,
    "Rm": 1000.0,
    "Pm": 1.0,
    "Omega": 0.6666666666666666,
    "S": 1.0,
    "q_shear": 1.5,
    "B0": 0.025,
    "nu": 0.001,
    "eta_mag": 0.001
  },
  "boundary_conditions": {
    "velocity": {"type": "no_slip_shearbox_walls"},
    "magnetic": {
      "type": "pseudo_vacuum",
      "details": "d_x b_x=0 (Neumann), b_y=b_z=0 (Dirichlet tangential)"
    }
  },
  "domain": {
    "x": [-1.0, 1.0],
    "y_period": 4.0,
    "z_period": 1.0
  },
  "resolution": {
    "smoke": {"Nx": 8, "Ny": 4, "Nz": 8, "dealias": 1.0},
    "start": {"Nx": 16, "Ny": 32, "Nz": 16},
    "production": {"Nx": 32, "Ny": 32, "Nz": 32},
    "dealias": {"x": 1.0, "y": 1.5, "z": 1.5},
    "family": "C"
  },
  "time": {
    "integrator": "CNAB2",
    "dt": 0.005,
    "final_time": 60.0
  },
  "initial_condition": {
    "type": "net_flux_3d_perturbed",
    "amplitude": 0.001,
    "seeded_modes": {"ky": 0, "kz": [1, 2, 3]},
    "nonaxisymmetric_seed": {"ky_mode": 1, "kz_mode": 1, "amplitude": 0.0001}
  },
  "forcing": {
    "type": "rotation_shear_imposed_vertical_field",
    "B0": 0.025,
    "by": 0.0,
    "bz": 0.025
  },
  "diagnostics": [
    "magnetic_energy",
    "growth_rate",
    "maxwell_stress_xy",
    "reynolds_stress",
    "total_stress",
    "transport_alpha",
    "alpha_Sh",
    "divergence_b_l2",
    "divergence_u_l2",
    "mean_by",
    "nonaxisymmetric_fraction"
  ],
  "expected_oracle": {
    "type": "mri_saturation_ladder",
    "source": "pseudo-vacuum linear eigenmode (couette/_pcf_linear.py), exp_pcf_mri_shearbox_growth conducting cross-check, then GPU-generated saturated DNS golden",
    "plan_inventory_id": "exp_PCF_MRI_pseudo_vacuum",
    "fallback_rungs": [1, 2, 3],
    "linear_window_check": "growth over t in [1,3]; saturation uses E_mag[-1] > 2*E_mag[0] and monotone-then-plateau"
  },
  "tolerance_model": {
    "kind": "dns-production",
    "scalars": {
      "divergence_b_l2": 1e-10,
      "divergence_u_l2": 1e-10,
      "growth_rate": 0.002,
      "magnetic_energy": 0.000001,
      "maxwell_stress_xy": 0.000001,
      "total_stress": 1e-06,
      "alpha_Sh": 1e-06,
      "mean_by": 1e-06,
      "nonaxisymmetric_fraction": 1e-06,
      "growth_rate_linear": 1e-06,
      "kinetic_energy": 1e-06,
      "magnetic_energy_growth_factor": 1e-06,
      "reynolds_stress": 1e-06,
      "total_energy": 1e-06,
      "transport_alpha": 1e-06
    }
  },
  "golden": {
    "artifact_id": "exp_pcf_mri_pseudo_vacuum",
    "regeneration_command": ".venv/bin/python production/run_problem.py --config production/runs/exp_pcf_mri_pseudo_vacuum.json --out runs/exp_pcf_mri_pseudo_vacuum/<timestamp> --device auto --write-golden"
  },
  "unsupported_subcases": []
}
